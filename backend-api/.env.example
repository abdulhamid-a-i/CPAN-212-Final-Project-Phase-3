import dotenv from "dotenv";

dotenv.config();

function requireEnv(name) {
  const value = process.env[name];
  if (!value || value.trim() === "") {
    throw new Error(`Missing required environment variable: ${name}`);
  }
  return value;
}

export const env = Object.freeze({
  nodeEnv: process.env.NODE_ENV || "development",
  port: Number(process.env.PORT || 5000),

  mongoUri: requireEnv("MONGODB_URI"),
  jwtSecret: requireEnv("JWT_SECRET"),
  jwtExpiresIn: process.env.JWT_EXPIRES_IN || "2h",

  frontendUrl: requireEnv("FRONTEND_URL"),

  httpsPfxPath: process.env.HTTPS_PFX_PATH || "",
  httpsPfxPassphrase: process.env.HTTPS_PFX_PASSPHRASE || "",

  keycloakBaseUrl: requireEnv("KEYCLOAK_BASE_URL"),
  keycloakRealm: requireEnv("KEYCLOAK_REALM"),
  keycloakClientId: requireEnv("KEYCLOAK_CLIENT_ID"),
  keycloakClientSecret: requireEnv("KEYCLOAK_CLIENT_SECRET"),
  keycloakBackendCallbackUrl: requireEnv("KEYCLOAK_BACKEND_CALLBACK_URL"),
  keycloakFrontendSuccessRedirectUrl: requireEnv("KEYCLOAK_FRONTEND_SUCCESS_REDIRECT_URL"),
  keycloakFrontendFailureRedirectUrl: requireEnv("KEYCLOAK_FRONTEND_FAILURE_REDIRECT_URL")
});